---
# Fill in real values then encrypt before committing:
#   sops --encrypt --in-place secret.sops.yaml
# (.sops.yaml in the repo root targets *.sops.yaml with the cluster PGP key.)
apiVersion: v1
kind: Secret
metadata:
  name: assistant-public-secrets
type: Opaque
stringData:
  # Strong bearer key for the public gateway API (referenced by configmap
  # API_SERVER_KEY via ${ASSISTANT_PUBLIC_API_KEY} — keep the var name in
  # common-secrets, OR inline here and drop the var-sub. See note below.)
  ASSISTANT_PUBLIC_API_KEY: ""
  # SSO / integration secrets as needed once auth provider is chosen
  # (pocket-id / oauth2-proxy client id+secret, etc.)
