# tinyauth config — consumed by the deployment via envFrom. rendered by a
# kustomize configMapGenerator (see kustomization.yaml) so the generated
# ConfigMap name carries a content hash: any edit here changes the name, which
# rewrites the deployment's envFrom ref and makes Flux roll the pod. without
# this, env from a ConfigMap is only read at pod start and a config edit never
# takes effect until a manual restart.
#
# NOTE: TINYAUTH_AUTH_ACLS_POLICY is main-branch-only; the released v5 image
# crashes on it ("field not found, node: acls"). default is allow.
TINYAUTH_APPURL=https://auth.keiretsu.top
TINYAUTH_SERVER_PORT=3000
TINYAUTH_AUTH_SESSIONEXPIRY=86400
TINYAUTH_AUTH_SECURECOOKIE=true
TINYAUTH_OAUTH_AUTOREDIRECT=google
TINYAUTH_AUTH_TRUSTEDPROXIES=10.0.0.0/8,192.168.0.0/16
TINYAUTH_LOG_LEVEL=trace
TINYAUTH_ANALYTICS_ENABLED=false
# authN gate: who may complete google login at all. per-app authZ lives on each
# route's SecurityPolicy (EG authorization on Remote-Email), not here. adding a
# user = append their google email here, then to the routes they should reach.
TINYAUTH_OAUTH_WHITELIST=rajsinghcpre@gmail.com,kartikbharath@gmail.com
