# syntax=docker/dockerfile:1
# SPDX-License-Identifier: MIT
#
# DSpark vLLM Runtime Overlay
#
# Builds a DSpark-enabled vLLM runtime for DeepSeek-V4-Flash-DSpark
# on 2x DGX Spark (GB10/Blackwell, SM12.1a).
#
# Base: ghcr.io/bjk110/vllm-spark:unholy-fusion-prod-ready
#   - Rafael Caricio's vLLM DSpark fork, compiled for sm_121
#   - B12X MoE kernels, DSpark speculative decoding support
# Overlay: Tony DeAngelo's validated patches from tonyd2wild's recipe
#
# Build:
#   docker build -t aidendle94/sparkrun-vllm-ds4-gb10:dspark \
#     -f Dockerfile.dspark-runtime .
#   docker push aidendle94/sparkrun-vllm-ds4-gb10:dspark

FROM ghcr.io/bjk110/vllm-spark:unholy-fusion-prod-ready

LABEL org.dspark.runtime="clean-overlay" \
      org.dspark.recipe="tonyd2wild/DeepSeek-v4-Flash-DSpark-60-tok-s--2x-DGX-Spark" \
      description="DSpark vLLM runtime for DeepSeek-V4-Flash-DSpark on 2x DGX Spark"

COPY vllm/envs.py /opt/env/lib/python3.12/site-packages/vllm/envs.py
COPY vllm/config/speculative.py /opt/env/lib/python3.12/site-packages/vllm/config/speculative.py
COPY vllm/model_executor/layers/fused_moe/b12x_moe.py /opt/env/lib/python3.12/site-packages/vllm/model_executor/layers/fused_moe/b12x_moe.py
COPY vllm/model_executor/warmup/kernel_warmup.py /opt/env/lib/python3.12/site-packages/vllm/model_executor/warmup/kernel_warmup.py
COPY vllm/v1/attention/backends/mla/b12x_mla_sparse.py /opt/env/lib/python3.12/site-packages/vllm/v1/attention/backends/mla/b12x_mla_sparse.py
COPY vllm/v1/attention/backends/registry.py /opt/env/lib/python3.12/site-packages/vllm/v1/attention/backends/registry.py
COPY vllm/v1/core/sched/scheduler.py /opt/env/lib/python3.12/site-packages/vllm/v1/core/sched/scheduler.py
COPY vllm/v1/outputs.py /opt/env/lib/python3.12/site-packages/vllm/v1/outputs.py
COPY vllm/v1/spec_decode/dspark.py /opt/env/lib/python3.12/site-packages/vllm/v1/spec_decode/dspark.py
COPY vllm/v1/spec_decode/dspark_proposer.py /opt/env/lib/python3.12/site-packages/vllm/v1/spec_decode/dspark_proposer.py
COPY vllm/v1/worker/gpu_model_runner.py /opt/env/lib/python3.12/site-packages/vllm/v1/worker/gpu_model_runner.py

# Pre-compile patched files to catch import errors at build time
RUN /opt/env/bin/python -m py_compile \
    /opt/env/lib/python3.12/site-packages/vllm/envs.py \
    /opt/env/lib/python3.12/site-packages/vllm/config/speculative.py \
    /opt/env/lib/python3.12/site-packages/vllm/model_executor/layers/fused_moe/b12x_moe.py \
    /opt/env/lib/python3.12/site-packages/vllm/model_executor/warmup/kernel_warmup.py \
    /opt/env/lib/python3.12/site-packages/vllm/v1/attention/backends/registry.py \
    /opt/env/lib/python3.12/site-packages/vllm/v1/attention/backends/mla/b12x_mla_sparse.py \
    /opt/env/lib/python3.12/site-packages/vllm/v1/core/sched/scheduler.py \
    /opt/env/lib/python3.12/site-packages/vllm/v1/outputs.py \
    /opt/env/lib/python3.12/site-packages/vllm/v1/spec_decode/dspark.py \
    /opt/env/lib/python3.12/site-packages/vllm/v1/spec_decode/dspark_proposer.py \
    /opt/env/lib/python3.12/site-packages/vllm/v1/worker/gpu_model_runner.py
