{
  "title": "Zot Registry",
  "uid": "zot-registry",
  "tags": ["zot", "registry"],
  "editable": true,
  "graphTooltip": 1,
  "refresh": "30s",
  "schemaVersion": 38,
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "links": [],
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "job",
        "label": "Registry",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "mimir" },
        "query": "label_values(zot_http_requests_total, job)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "sort": 1,
        "current": {}
      },
      {
        "name": "repo",
        "label": "Repo",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "mimir" },
        "query": "label_values(zot_repo_storage_bytes{job=~\"$job\"}, repo)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "sort": 1,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Traffic & Errors",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Requests / sec",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 } },
      "targets": [
        {
          "expr": "sum(rate(zot_http_requests_total{job=~\"$job\"}[5m]))",
          "legendFormat": "rps",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate (5xx)",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 4, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(zot_http_requests_total{job=~\"$job\",code=~\"5..\"}[5m])) / sum(rate(zot_http_requests_total{job=~\"$job\"}[5m]))",
          "legendFormat": "errors",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Storage",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 8, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "sum(zot_repo_storage_bytes{job=~\"$job\"})",
          "legendFormat": "total",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Push Rate (POST/PUT/PATCH)",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 12, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 } },
      "targets": [
        {
          "expr": "sum(rate(zot_http_requests_total{job=~\"$job\",method=~\"POST|PUT|PATCH\"}[5m]))",
          "legendFormat": "push",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Pull Rate (GET/HEAD)",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 16, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "reqps", "decimals": 2 } },
      "targets": [
        {
          "expr": "sum(rate(zot_http_requests_total{job=~\"$job\",method=~\"GET|HEAD\"}[5m]))",
          "legendFormat": "pull",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Blackbox Probe",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 20, "y": 1, "w": 4, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "max(probe_success{service=\"zot\"})",
          "legendFormat": "up",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requests by Method",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "sum by (method) (rate(zot_http_requests_total{job=~\"$job\"}[5m]))",
          "legendFormat": "{{method}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Requests by Status Code",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "sum by (code) (rate(zot_http_requests_total{job=~\"$job\"}[5m]))",
          "legendFormat": "HTTP {{code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 40,
      "type": "timeseries",
      "title": "5xx Error Timeline",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 7 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] } },
      "targets": [
        {
          "expr": "sum by (code) (rate(zot_http_requests_total{job=~\"$job\",code=~\"5..\"}[5m]))",
          "legendFormat": "HTTP {{code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Latency (the bottleneck view)",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Request Latency by Method (p50 / p95 / p99)",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 0, "y": 22, "w": 16, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, method) (rate(zot_http_method_latency_seconds_bucket{job=~\"$job\"}[5m])))",
          "legendFormat": "p50 {{method}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, method) (rate(zot_http_method_latency_seconds_bucket{job=~\"$job\"}[5m])))",
          "legendFormat": "p95 {{method}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, method) (rate(zot_http_method_latency_seconds_bucket{job=~\"$job\"}[5m])))",
          "legendFormat": "p99 {{method}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Push Latency (POST/PUT/PATCH p95) — the S3 write path",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 16, "y": 22, "w": 8, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(zot_http_method_latency_seconds_bucket{job=~\"$job\",method=~\"POST|PUT|PATCH\"}[5m])))",
          "legendFormat": "p95 push",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(zot_http_method_latency_seconds_bucket{job=~\"$job\",method=~\"POST|PUT|PATCH\"}[5m])))",
          "legendFormat": "p50 push",
          "refId": "B"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Mean Latency by Repo",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 0, "y": 30, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean"] } },
      "targets": [
        {
          "expr": "topk(10, rate(zot_http_repo_latency_seconds_sum{job=~\"$job\",repo=~\"$repo\"}[5m]) / rate(zot_http_repo_latency_seconds_count{job=~\"$job\",repo=~\"$repo\"}[5m]))",
          "legendFormat": "{{repo}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Pull Latency (GET/HEAD p95) — the cache hit path",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 12, "y": 30, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(zot_http_method_latency_seconds_bucket{job=~\"$job\",method=~\"GET|HEAD\"}[5m])))",
          "legendFormat": "p95 pull",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(zot_http_method_latency_seconds_bucket{job=~\"$job\",method=~\"GET|HEAD\"}[5m])))",
          "legendFormat": "p50 pull",
          "refId": "B"
        }
      ]
    },
    {
      "id": 20,
      "type": "row",
      "title": "Storage & Transfer",
      "gridPos": { "x": 0, "y": 38, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 21,
      "type": "table",
      "title": "Storage by Repo",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 0, "y": 39, "w": 8, "h": 10 },
      "fieldConfig": {
        "defaults": { "unit": "bytes" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "repo" }, "properties": [{ "id": "custom.width", "value": 200 }] }
        ]
      },
      "options": { "sortBy": [{ "displayName": "Value", "desc": true }], "footer": { "show": true, "reducer": ["sum"] } },
      "targets": [
        {
          "expr": "sort_desc(sum by (repo) (zot_repo_storage_bytes{job=~\"$job\",repo=~\"$repo\"}))",
          "legendFormat": "{{repo}}",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        { "id": "filterFieldsByName", "options": { "include": { "names": ["repo", "Value"] } } },
        { "id": "organize", "options": { "renameByName": { "Value": "Size" } } }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "Downloads / sec (top 10 repos)",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 8, "y": 39, "w": 8, "h": 10 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "topk(10, sum by (repo) (rate(zot_repo_downloads_total{job=~\"$job\",repo=~\"$repo\"}[5m])))",
          "legendFormat": "{{repo}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Uploads / sec (top 10 repos)",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 16, "y": 39, "w": 8, "h": 10 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "topk(10, sum by (repo) (rate(zot_repo_uploads_total{job=~\"$job\",repo=~\"$repo\"}[5m])))",
          "legendFormat": "{{repo}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 30,
      "type": "row",
      "title": "Scheduler & GC",
      "gridPos": { "x": 0, "y": 49, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Task Queue Length",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 0, "y": 50, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "expr": "sum by (job) (zot_scheduler_tasksqueue_length{job=~\"$job\"})",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Scheduler Workers",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 12, "y": 50, "w": 12, "h": 7 },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "expr": "sum by (job, state) (zot_scheduler_workers{job=~\"$job\"})",
          "legendFormat": "{{job}} {{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 50,
      "type": "row",
      "title": "Garage S3 Backend Health",
      "gridPos": { "x": 0, "y": 57, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 51,
      "type": "stat",
      "title": "Garage Serving Health",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 0, "y": 58, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "max(probe_success{service=\"garage\", check=\"serving\", target=\"local\"})",
          "legendFormat": "serving",
          "refId": "A"
        }
      ]
    },
    {
      "id": 52,
      "type": "stat",
      "title": "Garage Gateway Reachable",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 6, "y": 58, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "max(probe_success{service=\"garage\", tier=\"gateway\", check=\"port-open\", target=\"local\"})",
          "legendFormat": "gateway",
          "refId": "A"
        }
      ]
    },
    {
      "id": 53,
      "type": "timeseries",
      "title": "Garage Resync Queue Length (write backlog)",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 12, "y": 58, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["last", "max"] } },
      "targets": [
        {
          "expr": "max by (instance) (garage_block_resync_queue_length)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 54,
      "type": "timeseries",
      "title": "Garage S3 API Errors",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 0, "y": 66, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "reqps" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] } },
      "targets": [
        {
          "expr": "sum by (status) (rate(garage_s3_request_total{status=~\"5..\"}[5m]))",
          "legendFormat": "S3 {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 55,
      "type": "timeseries",
      "title": "Garage S3 API Latency (p95)",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 12, "y": 66, "w": 12, "h": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max"] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(garage_s3_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 S3",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(garage_s3_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 S3",
          "refId": "B"
        }
      ]
    },
    {
      "id": 60,
      "type": "row",
      "title": "Cache (Dragonfly)",
      "gridPos": { "x": 0, "y": 74, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 61,
      "type": "stat",
      "title": "Cache Memory Used",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 0, "y": 75, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "bytes" } },
      "targets": [
        {
          "expr": "max(dragonfly_used_memory_bytes)",
          "legendFormat": "used",
          "refId": "A"
        }
      ]
    },
    {
      "id": 62,
      "type": "stat",
      "title": "Cache Keys",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 6, "y": 75, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "expr": "sum(dragonfly_keys_total)",
          "legendFormat": "keys",
          "refId": "A"
        }
      ]
    },
    {
      "id": 63,
      "type": "timeseries",
      "title": "Cache Ops / sec",
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "gridPos": { "x": 12, "y": 75, "w": 12, "h": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" } },
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] } },
      "targets": [
        {
          "expr": "sum by (type) (rate(dragonfly_commands_total[5m]))",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 64,
      "type": "timeseries",
