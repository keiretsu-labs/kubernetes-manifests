{
  "$schema": "https://opencode.ai/config.json",
  "model": "aperture/deepseek-v4-flash",
  "provider": {
    "aperture": {
      "name": "Aperture (self-hosted)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://aperture/v1",
        "apiKey": "-"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "attachment": false,
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "limit": { "context": 200000, "output": 16384 }
        }
      }
    },
    "ai": {
      "name": "Aperture (ai provider)",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://aperture/v1",
        "apiKey": "-"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek V4 Flash",
          "attachment": false,
          "reasoning": true,
          "tool_call": true,
          "temperature": true,
          "limit": { "context": 200000, "output": 16384 }
        }
      }
    }
  },
  "agent": {
    "subagent": {
      "model": "aperture/deepseek-v4-flash"
    }
  },
  "mcp": {
    "holmes": {
      "type": "remote",
      "url": "http://ottawa-holmes-mcp.keiretsu.ts.net/mcp",
      "enabled": true
    }
  }
}
